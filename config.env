#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# config.env — Single configuration file for multi-region-nonpaired-azurestorage
#
# Edit values here OR override via CLI flags on individual scripts.
# Precedence: CLI flags > environment variables > config.env > built-in defaults
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure infrastructure ──────────────────────────
SOURCE_REGION="swedencentral"        # Source storage account region
DEST_REGION="norwayeast"             # Destination storage account region (non-paired)
RESOURCE_GROUP="rg-objrepl-demo"     # Resource group name
SUBSCRIPTION=""                      # Azure subscription ID (blank = current default)

# ── Storage accounts ──────────────────────────────
SOURCE_STORAGE="objreplsrc736208"    # Source account name (auto-generated if blank)
DEST_STORAGE="objrepldst736208"      # Destination account name (auto-generated if blank)
CONTAINER_COUNT="5"                  # Number of blob containers to create (default 5)
SOURCE_CONTAINER_PREFIX="source"     # Source container name prefix (containers: source-01, source-02, …)
DEST_CONTAINER_PREFIX="dest"         # Destination container name prefix (containers: dest-01, dest-02, …)

# ── Replication settings ──────────────────────────
REPLICATION_MODE="default"           # "default" or "priority"
                                     #   default  — async replication, no SLA, no extra per-GB cost
                                     #   priority — 99% within 15 min SLA (same continent), per-GB ingress cost

# ── Benchmark data generation — benchmarking only ─────────
DATA_SIZE_GB="1"                     # Total data volume to generate (supports decimals: 0.5, 5, 50)
ACI_COUNT="1"                        # Number of ACI instances (AzDataMaker only; local uploads ignore this)
MAX_FILE_SIZE="12"                   # Max file size in MiB
MIN_FILE_SIZE="8"                    # Min file size in MiB
FILE_COUNT=""                        # Override: set explicitly to skip auto-calculation from DATA_SIZE_GB

# ── Optional AzDataMaker infra — benchmarking only ───────
ACR_NAME="objreplacr6a1c0d"           # Container registry name for optional AzDataMaker runs (auto-generated if blank)
ACI_PREFIX="azdatamaker"             # ACI instance name prefix for optional AzDataMaker runs
